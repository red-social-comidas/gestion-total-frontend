# =============================================================================
# Gestion Total Portal — Variables de entorno
# Copiar a .env.local para desarrollo y NO commitear valores reales
# =============================================================================

# URL base de la API (sin /api/v1 al final — se agrega en axios.js)
VITE_API_URL=http://localhost:8000/api/v1

# Slug del tenant (debe coincidir con tenants.slug en Postgres)
VITE_TENANT_SLUG=mi-negocio
